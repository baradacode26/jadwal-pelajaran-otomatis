FROM node:18-alpine

# Set working directory
WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies
RUN npm ci

# Copy source code
COPY src ./src
COPY tsconfig.json ./
COPY vite.config.ts ./
COPY index.html ./
public ./

# Expose port
EXPOSE 3000

# Start development server
CMD ["npm", "run", "dev"]
